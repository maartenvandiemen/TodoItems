@inject TodoApiService TodoService
@implements IDisposable

<div class="todo-list" aria-label="Todo items" aria-live="polite">
    @if (!TodoService.FilteredItems.Any())
    {
        <div class="empty-state" role="status">
            <span class="empty-icon" aria-hidden="true">◈</span>
            <p>No tasks here. Add one above!</p>
        </div>
    }
    else
    {
        @foreach (var item in TodoService.FilteredItems.ToList())
        {
            <div class="list-item-wrap @(IsNew(item) ? "entering" : "")"
                 @key="item.Id">
                <TodoItemRow Item="@item" />
            </div>
        }
    }
</div>

@code {
    // Track newly-added item Ids to apply entry animation
    private HashSet<int> _newIds = [];

    protected override void OnInitialized()
    {
        TodoService.StateChanged += OnStateChanged;
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        TodoService.StateChanged -= OnStateChanged;
    }

    protected override void OnParametersSet()
    {
        // Items already handle animation via CSS class on add
    }

    private bool IsNew(TodoItem item) => _newIds.Contains(item.Id);

    public void MarkAsNew(int id)
    {
        _newIds.Add(id);
        StateHasChanged();
        // Remove the "new" marker after animation duration
        _ = RemoveNewMarkerAsync(id);
    }

    private async Task RemoveNewMarkerAsync(int id)
    {
        await Task.Delay(400);
        _newIds.Remove(id);
        StateHasChanged();
    }
}
